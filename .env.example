# Abyssal Assets — Environment Configuration
# Copy to .env and fill in values

# ===========================
# DATABASE
# ===========================
# PostgreSQL (Production)
DATABASE_URL=postgresql://abyssal:your_secure_password@localhost:5432/abyssal_assets

# PostgreSQL Individual (Alternative)
POSTGRES_USER=abyssal
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=abyssal_assets
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Local Development (SQLite)
# DATABASE_URL=sqlite:///./abyssal_assets.db

# ===========================
# REDIS
# ===========================
REDIS_URL=redis://localhost:6379

# ===========================
# SECURITY
# ===========================
# Generate with: openssl rand -hex 32
SECRET_KEY=your_32_byte_secret_key_here_min_64_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ===========================
# CORS / FRONTEND
# ===========================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000

# ===========================
# FRONTEND URLs
# ===========================
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ===========================
# WebSocket
# ===========================
WS_HEARTBEAT_INTERVAL=30000

# ===========================
# Rate Limiting
# ===========================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ===========================
# Market Configuration
# ===========================
MARKET_FEE_PERCENT=3
MARKET_FEE_BURN_PERCENT=1
MARKET_FEE_TREASURY_PERCENT=2
MARKET_MAKER_SPREAD=0.02

# ===========================
# Dredging Configuration
# ===========================
DREDGE_BASE_SUCCESS_RATE=0.7
DREDGE_CLout_BONUS_PER_1000=0.05
DREDGE_DEPTH_PENALTY=0.02

# ===========================
# Game Balance
# ===========================
STARTING_SOUL_COINS=1000
STARTING_CLOUT=0
STARTING_ZONE=shallows
STARTING_BOAT_LEVEL=1

# ===========================
# Zone Resonance Requirements
# ===========================
ZONE_SHALLOWS_REQ=0
ZONE_STANDARD_REQ=100
ZONE_DEEP_REQ=500
ZONE_ABYSSAL_REQ=1000
ZONE_TRENCH_REQ=100000

# ===========================
# Features
# ===========================
ENABLE_WEB3=false
ENABLE_MARKET_MAKERS=true
ENABLE_ANTI_CHEAT=true
DEBUG_MODE=true